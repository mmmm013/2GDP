{
  "name": "gputnam-music",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "gift:verify:prod": "node scripts/verify-gift-session.mjs",
    "perf:http:prod": "node scripts/perf-http-prod.mjs",
    "perf:e2e:prod": "PLAYWRIGHT_BASE_URL=https://www.gputnammusic.com playwright test tests/revenue-funnel.perf.spec.ts",
    "perf:prod": "npm run perf:http:prod && npm run perf:e2e:prod",
    "audio:validate": "node scripts/validate-audio-assets.mjs",
    "audio:smoke:local": "node scripts/audio-smoke.mjs http://localhost:3000",
    "audio:smoke:prod": "node scripts/audio-smoke.mjs https://www.gputnammusic.com",
    "audio:verify": "npm run audio:validate && npm run audio:smoke:prod",
    "creator:auth:validate:prod": "bash scripts/creator-auth-validate-prod.sh",
    "creator:auth:validate:preview": "bash scripts/creator-auth-validate-preview.sh",
    "creator:auth:validate:dev": "bash scripts/creator-auth-validate-dev.sh",
    "creator:auth:validate:all": "npm run creator:auth:validate:dev && npm run creator:auth:validate:preview && npm run creator:auth:validate:prod",
    "audio:e2e:install": "playwright install chromium",
    "audio:e2e:local": "playwright test tests/audio.e2e.spec.ts",
    "audio:e2e:prod": "PLAYWRIGHT_BASE_URL=https://www.gputnammusic.com playwright test tests/audio.e2e.spec.ts",
    "deploy:flagship:prod": "DEPLOY_CONFIRM=gputnammusic.com bash scripts/deploy-flagship.sh",
    "deploy:kkut:prod": "DEPLOY_CONFIRM=k-kut.com bash scripts/deploy-k-kut.sh",
    "deploy:hygiene": "bash scripts/check-deploy-hygiene.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "next": "15.5.15",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.99.0",
    "@vercel/analytics": "^1.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.300.0",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^20.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "next": "^16.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
