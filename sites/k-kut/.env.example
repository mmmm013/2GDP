# K-KUT Environment Variables
# Copy this file to .env.local and fill in your values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Required for Stripe webhook signature verification (/api/stripe/webhook)
# Get this from Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Sovereign Pass price ID — from Stripe Dashboard → Products → Sovereign Pass
STRIPE_SOVEREIGN_PRICE_ID=price_...
# Price IDs for other Heart-Tap tiers (rolling-out plans)
STRIPE_PRICE_ID_199=price_...
STRIPE_PRICE_ID_499=price_...
STRIPE_PRICE_ID_999=price_...

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://k-kut.com
