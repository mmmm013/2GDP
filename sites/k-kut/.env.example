# K-KUT Environment Variables
# Copy this file to .env.local and fill in your values.
#
# ─── Vercel Preview (audio-only) ─────────────────────────────────────────────
# Minimum required for the audio experience to work in a Preview deployment:
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
#   NEXT_PUBLIC_SITE_URL
#
# Stripe is OPTIONAL in Preview.  When Stripe env vars are absent the checkout
# and webhook routes degrade gracefully so the rest of the app (audio, demos,
# notify) keeps working.
#
# ─── Vercel Production (full experience) ─────────────────────────────────────
# All variables below are required for a fully functional production deployment.
# ─────────────────────────────────────────────────────────────────────────────

# --- Supabase (REQUIRED – audio delivery depends on these) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key is used server-side for notify sign-ups and webhooks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (optional in Preview, required in Production) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Required for Stripe webhook signature verification (/api/stripe/webhook).
# Get from: Stripe Dashboard → Developers → Webhooks → [your endpoint] → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Sovereign Pass price ID — from Stripe Dashboard → Products → Sovereign Pass → Price ID
STRIPE_SOVEREIGN_PRICE_ID=price_...

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://k-kut.com
