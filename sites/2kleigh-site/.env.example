# 2kleigh.com — Environment Variables
# Copy to .env.local and fill in before running locally.
# In Vercel: Settings → Environment Variables → add each key.

# ── Vercel deployment ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://www.2kleigh.com

# ── Stripe (KUB sponsorship checkout) ────────────────────────────────────────
STRIPE_SECRET_KEY=
# KUB Stripe Payment Link (direct link — no server needed for initial version)
NEXT_PUBLIC_KUB_STRIPE_LINK=https://buy.stripe.com/4gM14n4KD8Zg1zI8ZO9IQ03
