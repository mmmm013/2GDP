# Copy this file to .env.local and fill in values before running or deploying.
# In Vercel: Settings → Environment Variables → add each key.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — used by both client and server (canonical env var)
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe to expose client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role key — server-only, NEVER expose client-side
SUPABASE_SERVICE_ROLE_KEY=

# ── Creator Portal ────────────────────────────────────────────────────────────
# Short-lived session JWT secret (4hr sessions)
# Generate: openssl rand -hex 32
CREATOR_SESSION_SECRET=

# WebAuthn Relying Party — must match production domain
NEXT_PUBLIC_WEBAUTHN_RP_ID=gputnammusic.com
NEXT_PUBLIC_WEBAUTHN_ORIGIN=https://gputnammusic.com

# ── Vercel Cron ───────────────────────────────────────────────────────────────
# Set in Vercel dashboard → Settings → Environment Variables
CRON_SECRET=
