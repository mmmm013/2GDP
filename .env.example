# Copy this file to .env.local and fill in values before running or deploying

# Supabase – public keys (safe to expose to the browser)
# POST /api/log-stream-time uses cookie-based Supabase Auth; no service-role
# key is required for that endpoint.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Optional: deployment URL
NEXT_PUBLIC_VERCEL_URL=
