# Copy this file to .env.local and fill in values before running or deploying

# Supabase (used for streaming proxy)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Audio — canonical Supabase tracks bucket base URL (required for production audio)
# Format: https://<project-ref>.supabase.co/storage/v1/object/public/tracks/
NEXT_PUBLIC_SUPABASE_TRACKS_BASE_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Optional: deployment URL
NEXT_PUBLIC_VERCEL_URL=

# Security: Vercel Cron Jobs bearer token (set in Vercel dashboard → Settings → Environment Variables)
CRON_SECRET=

# 4PE Bestowal Engine: bearer token for POST /api/bestowal
# Generate a strong random secret: openssl rand -hex 32
BESTOWAL_API_KEY=

# ── Creator Portal (GPM 4PE-MSC) ──────────────────────────────────
# Short-lived session JWT secret for creator portals (4hr sessions)
# Generate: openssl rand -hex 32
CREATOR_SESSION_SECRET=

# WebAuthn Relying Party configuration
# RP ID must match the domain (no protocol, no port)
NEXT_PUBLIC_WEBAUTHN_RP_ID=gputnammusic.com
# RP Origin must be the full origin (protocol + domain + optional port)
NEXT_PUBLIC_WEBAUTHN_ORIGIN=https://gputnammusic.com
