# Copy this file to .env.local and fill in values before running or deploying

# Supabase – public keys (safe to expose to the browser)
# POST /api/log-stream-time uses cookie-based Supabase Auth; no service-role
# key is required for that endpoint.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase – server-only service role key (NEVER expose to the browser)
# Required by supabaseAdmin for webhook handlers, cron jobs, and admin routes.
# Generate in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Audio — canonical Supabase tracks bucket base URL (required for production audio)
# Format: https://<project-ref>.supabase.co/storage/v1/object/public/tracks/
NEXT_PUBLIC_SUPABASE_TRACKS_BASE_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Stripe webhook signing secret — get from: Stripe Dashboard → Webhooks → endpoint → Signing secret
# Required by /api/webhooks/stripe to verify event authenticity
STRIPE_WEBHOOK_SECRET=

# App base URL — used for gift claim links in SMS notifications
# e.g. https://gputnammusic.com (no trailing slash)
NEXT_PUBLIC_BASE_URL=

# Optional: deployment URL
NEXT_PUBLIC_VERCEL_URL=

# Security: Vercel Cron Jobs bearer token (set in Vercel dashboard → Settings → Environment Variables)
CRON_SECRET=

# 4PE Bestowal Engine: bearer token for POST /api/bestowal
# Generate a strong random secret: openssl rand -hex 32
BESTOWAL_API_KEY=

# ── Creator Portal (GPM 4PE-MSC) ──────────────────────────────────
# Short-lived session JWT secret for creator portals (4hr sessions)
# Generate: openssl rand -hex 32
CREATOR_SESSION_SECRET=

# WebAuthn Relying Party configuration
# RP ID must match the domain (no protocol, no port)
NEXT_PUBLIC_WEBAUTHN_RP_ID=gputnammusic.com
# RP Origin must be the full origin (protocol + domain + optional port)
NEXT_PUBLIC_WEBAUTHN_ORIGIN=https://gputnammusic.com

# ── Twilio SMS (optional) ───────────────────────────────────────────
# Required for post-purchase gift SMS notifications in /api/webhooks/stripe
# Leave blank to skip SMS (safe for development)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── MSJ Revenue Dashboard ───────────────────────────────────────────
# Secret token for the private MSJ revenue transparency page at /msj-revenue
# Share this URL privately with Michael Scherer: /msj-revenue?token=<value>
# Generate: openssl rand -hex 32
MSJ_DASHBOARD_TOKEN=
